    "@atproto/api": "^0.19.6",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@iconify-json/devicon": "^1.2.61",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/system-uicons": "^1.2.4",
    "@pagefind/default-ui": "^1.4.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "astro": "^5.18.1",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0",
