---
import { SEO } from 'astro-seo';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import '@/styles/global.css';
import { siteConfig } from '@/data/seo';
import { ClientRouter } from 'astro:transitions';

const { pageTitle, description, ogImage, ogImageAlt } = Astro.props;
const siteUrl = Astro.site?.href.replace(/\/$/, '') || 'https://blog.lcyou.me';
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
const defaultOgImage = `${siteUrl}/og-default.png`;
const ogImageUrl = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`)
  : defaultOgImage;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={pageTitle ? `${pageTitle} | ${siteConfig.title}` : siteConfig.title}
      description={description}
      canonical={pageUrl}
      openGraph={{
        basic: {
          title: pageTitle || siteConfig.title,
          type: 'website',
          image: ogImageUrl,
          url: pageUrl,
        },
        optional: {
          description: description,
          locale: siteConfig.locale,
          siteName: siteConfig.title,
        },
        image: {
          alt: ogImageAlt || pageTitle || siteConfig.title,
          width: 1200,
          height: 630,
        },
      }}
      twitter={{
        card: 'summary_large_image',
	image: ogImageUrl,	    
	site: siteConfig.twitter,
        creator: siteConfig.twitter,
      }}
    />
    <script is:inline>
      // ページロード前にテーマを適用（フラッシュ防止）
      (function() {
        const storedTheme = localStorage.getItem('theme');
        const theme = storedTheme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <ClientRouter />
    <script is:inline>
      (() => {
        const homePath = '/';
        const transitionName = 'hero-main';
        const normalizePath = (pathname) => pathname.replace(/\/$/, '') || '/';
        const isHomeTransition = (from, to) => {
          const fromHome = normalizePath(from.pathname) === homePath;
          const toHome = normalizePath(to.pathname) === homePath;
          return fromHome !== toHome;
        };
        const transitionDirection = (from, to) => {
          return normalizePath(from.pathname) === homePath ? 'from-hero' : 'to-hero';
        };
        const transitionRoot = (doc, pathname) => {
          return normalizePath(pathname) === homePath
            ? doc.querySelector('.home')
            : doc.querySelector('.page-content');
        };
        const clearTransitionRoots = (doc) => {
          doc.documentElement.removeAttribute('data-hero-transition');
          doc.querySelectorAll('[data-hero-transition-root]').forEach((el) => {
            el.style.viewTransitionName = '';
            el.removeAttribute('data-hero-transition-root');
          });
        };
        const markTransitionRoot = (el) => {
          if (!el) return;
          el.style.viewTransitionName = transitionName;
          el.setAttribute('data-hero-transition-root', '');
        };

        document.addEventListener('astro:before-preparation', (event) => {
          clearTransitionRoots(document);
          if (!isHomeTransition(event.from, event.to)) return;

          const direction = transitionDirection(event.from, event.to);
          document.documentElement.setAttribute('data-hero-transition', direction);
          markTransitionRoot(transitionRoot(document, event.from.pathname));

          const defaultLoader = event.loader;
          event.loader = async () => {
            await defaultLoader();
            clearTransitionRoots(event.newDocument);
            event.newDocument.documentElement.setAttribute('data-hero-transition', direction);
            markTransitionRoot(transitionRoot(event.newDocument, event.to.pathname));
          };
        });

        document.addEventListener('astro:before-swap', (event) => {
          if (!isHomeTransition(event.from, event.to)) return;
          event.viewTransition.finished.finally(() => clearTransitionRoots(document));
        });

        document.addEventListener('astro:page-load', () => clearTransitionRoots(document));
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <ThemeToggle />
    <Header />
	    <slot />
    <Footer />
  </body>
</html>
